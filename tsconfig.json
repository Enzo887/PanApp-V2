{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,
    "strict": true,

    "isolatedModules": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  }
}